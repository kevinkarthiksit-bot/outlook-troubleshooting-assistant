  "guides": [
    {
      "id": "GEVKB0020001",
      "title": "Outlook not responding, freezes, or stops working",
      "category": "Performance & Stability",
      "client": "both",
      "keywords": [
        "freeze",
        "hang",
        "not responding",
        "crash",
        "stuck"
      ],
      "symptoms": [
        "Outlook freezes",
        "Outlook not responding dialog",
        "Outlook hangs on startup"
      ],
      "priority": 1,
      "url": "https://learn.microsoft.com/en-us/troubleshoot/outlook/performance/outlook-not-responding-error-or-outlook-freezes",
      "steps": [
        {
          "text": "Install latest Windows and Microsoft 365 updates.",
          "tip": "Outdated builds are a common cause of hangs."
        },
        {
          "text": "Close Outlook completely in Task Manager if stuck.",
          "platforms": [
            "Windows"
          ]
        },
        {
          "text": "Start Outlook in safe mode: Win+R, type outlook.exe /safe, press Enter.",
          "image": "assets/images/safe-mode-run.svg",
          "alt": "Run dialog for safe mode",
          "platforms": [
            "Windows"
          ]
        },
        {
          "text": "If safe mode works, disable COM add-ins: File > Options > Add-ins.",
          "image": "assets/images/add-ins-manager.svg",
          "alt": "COM Add-ins manager",
          "platforms": [
            "Windows"
          ]
        },
        {
          "text": "Run Office Quick Repair from Settings > Apps > Microsoft 365 > Modify.",
          "image": "assets/images/office-repair.svg",
          "alt": "Office repair",
          "platforms": [
            "Windows"
          ]
        },
        "If issue persists, create a new Outlook profile or escalate with exact error text."
      ]
    },
    {
      "id": "GEVKB0020002",
      "title": "Start Outlook in Safe Mode and disable add-ins",
      "category": "Performance & Stability",
      "client": "classic",
      "keywords": [
        "safe mode",
        "add-in",
        "com add-in",
        "startup"
      ],
      "symptoms": [
        "Outlook crashes on startup",
        "Add-in caused crash"
      ],
      "priority": 1,
      "url": "https://learn.microsoft.com/en-us/troubleshoot/outlook/performance/outlook-not-responding-error-or-outlook-freezes",
      "steps": [
        {
          "text": "Press Win+R, type outlook.exe /safe, click OK.",
          "image": "assets/images/safe-mode-run.svg",
          "alt": "Outlook safe mode command",
          "platforms": [
            "Windows"
          ]
        },
        "If Outlook opens in safe mode, an add-in or extension is likely the cause.",
        {
          "text": "File > Options > Add-ins > Manage COM Add-ins > Go. Uncheck add-ins one at a time.",
          "image": "assets/images/add-ins-manager.svg",
          "alt": "Disable COM add-ins",
          "platforms": [
            "Windows"
          ]
        },
        "Restart Outlook normally after each change to identify the problematic add-in.",
        "Contact add-in vendor or IT if a required add-in causes crashes."
      ]
    },
    {
      "id": "GEVKB0020003",
      "title": "Repair Microsoft 365 Office programs (Quick Repair)",
      "category": "Performance & Stability",
      "keywords": [
        "repair",
        "office repair",
        "quick repair",
        "online repair"
      ],
      "symptoms": [
        "Outlook broken after update",
        "Office corruption"
      ],
      "priority": 2,
      "url": "https://learn.microsoft.com/en-us/troubleshoot/office/troubleshoot-office-suite-issues",
      "steps": [
        {
          "text": "Open Windows Settings > Apps > Installed apps.",
          "platforms": [
            "Windows"
          ]
        },
        {
          "text": "Select Microsoft 365 > Modify > Quick Repair.",
          "image": "assets/images/office-repair.svg",
          "alt": "Office Quick Repair option",
          "platforms": [
            "Windows"
          ]
        },
        "Complete repair and restart the computer.",
        "If Quick Repair fails, run Online Repair (requires re-download).",
        "Test Outlook after repair before escalating."
      ]
    },
    {
      "id": "GEVKB0020004",
      "title": "Rebuild or reset the Outlook OST file",
      "category": "Connectivity & Sync",
